export PATH="$HOME/.asdf/shims:$PATH"
export PATH="$HOME/.asdf/bin:$PATH"
. "$(brew --prefix asdf)/libexec/asdf.sh"
eval "$(starship init zsh)"

# Tone down directory colors for ls in iTerm2.
export LSCOLORS="gxfxcxdxbxegedabagacad"

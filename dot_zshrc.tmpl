### Yazi wrapper ###
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  command yazi "$@" --cwd-file="$tmp"
  IFS= read -r -d "" cwd < "$tmp"
  [ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
  rm -f -- "$tmp"
}

function a() {
  local target="{{ $workspaceRoot }}"
  if [ -d "$target" ]; then
    builtin cd -- "$target"
  else
    printf 'Directory not found: %s\n' "$target" >&2
    return 1
  fi
}

# Expose a VS Code-compatible CLI as `code`.
if [ -d "{{ $vscodeCliDir }}" ]; then
  export PATH="{{ $vscodeCliDir }}:$PATH"
elif [ -d "/Applications/Cursor.app/Contents/Resources/app/bin" ]; then
  export PATH="/Applications/Cursor.app/Contents/Resources/app/bin:$PATH"
fi

code() {
  if [ "$#" -eq 0 ]; then
    command code .
  else
    command code "$@"
  fi
}

gacp() {
  local message

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'Not inside a git repository.\n' >&2
    return 1
  fi

  printf 'Commit message: '
  IFS= read -r message

  if [ -z "$message" ]; then
    printf 'Commit message cannot be empty.\n' >&2
    return 1
  fi

  git add . &&
    git commit -m "$message" &&
    git push
}

# Git branch workflow helpers
git_default_branch() {
  local ref
  ref=$(git symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null) || return 1
  printf '%s\n' "${ref##*/}"
}

gmain() {
  local base

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'Not inside a git repository.\n' >&2
    return 1
  fi

  base=$(git_default_branch)
  if [ -z "$base" ]; then
    printf 'Could not detect origin default branch.\n' >&2
    return 1
  fi

  git switch "$base"
}

gnew() {
  local name="$1"
  local base

  if [ -z "$name" ]; then
    printf 'Usage: gnew <branch-name>\n' >&2
    return 1
  fi

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'Not inside a git repository.\n' >&2
    return 1
  fi

  base=$(git_default_branch)
  if [ -z "$base" ]; then
    printf 'Could not detect origin default branch.\n' >&2
    return 1
  fi

  git fetch origin --prune &&
    git switch "$base" &&
    git pull --rebase --autostash origin "$base" &&
    git switch -c "$name"
}

gsync() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'Not inside a git repository.\n' >&2
    return 1
  fi

  git sync
}

gpublish() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'Not inside a git repository.\n' >&2
    return 1
  fi

  git publish
}

gprune() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'Not inside a git repository.\n' >&2
    return 1
  fi

  git fetch --all --prune &&
    git cleanup-merged
}

gbranches() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'Not inside a git repository.\n' >&2
    return 1
  fi

  git recent
}

ghelp() {
  cat <<'EOF'
Git 分支助手

  gnew <名称>         基于远端默认分支拉最新后创建新分支
  gmain               切回远端默认分支
  gsync               拉取并将当前分支 rebase 到上游分支
  gpublish            推送当前分支并自动设置 upstream
  gprune              删除已经合并的本地分支
  gbranches           按最近活跃时间列出本地分支
  lazygit             打开终端里的 Git 图形界面
  git-town            使用 Git Town 工作流命令

Git 快捷别名

  git st              查看简洁状态
  git co <分支>       切换分支
  git cob <名称>      创建并切换到新分支
  git br              按最近提交时间查看分支
  git recent          紧凑显示最近活跃分支
  git graph           图形化查看提交历史
  git up              pull 时自动 rebase 并 autostash
  git publish         推送当前分支并设置 upstream
  git sync            将当前分支 rebase 到上游分支
  git cleanup-merged  删除已经合并的本地分支
EOF
}
